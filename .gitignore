# macOS metadata
.DS_Store
._*

# Claude Code runtime data
claude/.claude/*
# Allow specific Claude config files
!claude/.claude/CLAUDE.md
!claude/.claude/CLAUDE-SPECIFIC.md

# Gemini runtime data (contains OAuth credentials)
gemini/.gemini/*
# Allow specific Gemini config files
!gemini/.gemini/GEMINI.md
!gemini/.gemini/GEMINI-SPECIFIC.md

# Personal config
.gitconfig.user
.ssh/config

# Config
karabiner/.config/karabiner/automatic_backups


# Files containing secrets
.env
.env.*
*.secret
*.credentials
*secret*
*credentials*
id_rsa*
id_ed25519*
*.pem
*.key
.netrc
.gcp*
.aws/credentials

# Editor temporary files
*.swp
*.swo
*~
.#*

# Common build/cache directories
node_modules/
*.pyc
__pycache__/
*.egg-info/
